			<string name="Name">极导表</string>
			<token name="RunContext">0</token>
			<string name="ScriptGuid">{DCA6C956-DEC2-4146-A689-4C1F5D799E55}</string>
<ProtectedString name="Source"><![CDATA[--[[
    极导表 — LarkExcel2Studio Studio 插件
    负责轮询本地 RoEzConfig 工具，获取数据并写入工程
    作者：Ian
]]

local FileWriter = require(script.FileWriter)

-- ========================================
-- 配置
-- ========================================

-- 轮询间隔（秒）-- Ian
local POLL_INTERVAL = 1

-- ========================================
-- 初始化 Toolbar
-- ========================================
local toolbar   = plugin:CreateToolbar("极导表")
local toggleBtn = toolbar:CreateButton("极导表", "极导表 - LarkExcel2Studio", "rbxassetid://83752827760423")
toggleBtn.ClickableWhenViewportHidden = true

-- ========================================
-- 创建 DockWidget 日志面板
-- ========================================
local widgetInfo = DockWidgetPluginGuiInfo.new(
    Enum.InitialDockState.Right,
    false, false, 300, 400, 250, 300
)
local widget = plugin:CreateDockWidgetPluginGui("RoEzConfig_Widget", widgetInfo)
widget.Title = "极导表"

-- 切换面板显隐 -- Ian
toggleBtn.Click:Connect(function()
    widget.Enabled = not widget.Enabled
end)

-- ========================================
-- 构建日志 UI
-- ========================================
local frame = Instance.new("Frame")
frame.Size = UDim2.new(1, 0, 1, 0)
frame.BackgroundColor3 = settings().Studio.Theme:GetColor(Enum.StudioStyleGuideColor.MainBackground)
frame.BorderSizePixel = 0
frame.Parent = widget

local titleLabel = Instance.new("TextLabel")
titleLabel.Size = UDim2.new(1, 0, 0, 32)
titleLabel.BackgroundColor3 = settings().Studio.Theme:GetColor(Enum.StudioStyleGuideColor.Titlebar)
titleLabel.BorderSizePixel = 0
titleLabel.Text = "  🚀 极导表 · LarkExcel2Studio"
titleLabel.TextColor3 = settings().Studio.Theme:GetColor(Enum.StudioStyleGuideColor.TitlebarText)
titleLabel.TextXAlignment = Enum.TextXAlignment.Left
titleLabel.Font = Enum.Font.SourceSansSemibold
titleLabel.TextSize = 14
titleLabel.Parent = frame

-- 端口配置区 -- Ian
local portFrame = Instance.new("Frame")
portFrame.Size = UDim2.new(1, 0, 0, 44)
portFrame.Position = UDim2.new(0, 0, 0, 32)
portFrame.BackgroundColor3 = settings().Studio.Theme:GetColor(Enum.StudioStyleGuideColor.Titlebar)
portFrame.BorderSizePixel = 0
portFrame.Parent = frame

local portLabel = Instance.new("TextLabel")
portLabel.Size = UDim2.new(0, 80, 1, 0)
portLabel.BackgroundTransparency = 1
portLabel.Text = "  插件端口:"
portLabel.TextColor3 = settings().Studio.Theme:GetColor(Enum.StudioStyleGuideColor.MainText)
portLabel.TextSize = 18
portLabel.Font = Enum.Font.SourceSans
portLabel.TextXAlignment = Enum.TextXAlignment.Left
portLabel.Parent = portFrame

local portInput = Instance.new("TextBox")
portInput.Size = UDim2.new(0, 100, 0, 30)
portInput.Position = UDim2.new(0, 82, 0, 7)
portInput.BackgroundColor3 = settings().Studio.Theme:GetColor(Enum.StudioStyleGuideColor.InputFieldBackground)
portInput.BorderSizePixel = 0
portInput.Text = "11451"
portInput.TextColor3 = settings().Studio.Theme:GetColor(Enum.StudioStyleGuideColor.MainText)
portInput.TextSize = 18
portInput.Font = Enum.Font.SourceSans
portInput.ClearTextOnFocus = false
portInput.Parent = portFrame

-- 保存端口按钮 -- Ian
local portSaveBtn = Instance.new("TextButton")
portSaveBtn.Size = UDim2.new(0, 80, 0, 30)
portSaveBtn.Position = UDim2.new(0, 190, 0, 7)
portSaveBtn.BackgroundColor3 = settings().Studio.Theme:GetColor(Enum.StudioStyleGuideColor.DialogMainButton)
portSaveBtn.TextColor3 = settings().Studio.Theme:GetColor(Enum.StudioStyleGuideColor.DialogMainButtonText)
portSaveBtn.Text = "保存端口"
portSaveBtn.TextSize = 14
portSaveBtn.Font = Enum.Font.SourceSansSemibold
portSaveBtn.BorderSizePixel = 0
portSaveBtn.Parent = portFrame

local portSaveCorner = Instance.new("UICorner")
portSaveCorner.CornerRadius = UDim.new(0, 4)
portSaveCorner.Parent = portSaveBtn


local logScroll = Instance.new("ScrollingFrame")
logScroll.Size = UDim2.new(1, 0, 1, -68)
logScroll.Position = UDim2.new(0, 0, 0, 68)
logScroll.BackgroundColor3 = settings().Studio.Theme:GetColor(Enum.StudioStyleGuideColor.MainBackground)
logScroll.BorderSizePixel = 0
logScroll.ScrollBarThickness = 4
logScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
logScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
logScroll.Parent = frame

local logLayout = Instance.new("UIListLayout")
logLayout.SortOrder = Enum.SortOrder.LayoutOrder
logLayout.Padding = UDim.new(0, 2)
logLayout.Parent = logScroll

local logPadding = Instance.new("UIPadding")
logPadding.PaddingLeft = UDim.new(0, 8)
logPadding.PaddingRight = UDim.new(0, 8)
logPadding.PaddingTop = UDim.new(0, 6)
logPadding.Parent = logScroll

-- ========================================
-- 日志函数
-- ========================================
local logCounter = 0

local function log(message, isError)
    logCounter = logCounter + 1
    local label = Instance.new("TextLabel")
    label.Name = "Log_" .. logCounter
    label.Size = UDim2.new(1, 0, 0, 0)
    label.AutomaticSize = Enum.AutomaticSize.Y
    label.BackgroundTransparency = 1
    label.Text = message
    label.TextSize = 13
    label.Font = Enum.Font.SourceSans
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextWrapped = true
    label.TextColor3 = isError
        and Color3.fromRGB(200, 60, 60)
        or settings().Studio.Theme:GetColor(Enum.StudioStyleGuideColor.MainText)
    label.LayoutOrder = logCounter
    label.Parent = logScroll

    -- 自动滚动到底部 -- Ian
    task.defer(function()
        logScroll.CanvasPosition = Vector2.new(0, logScroll.AbsoluteCanvasSize.Y)
    end)
end


-- 点击保存端口，提示重启 Studio -- Ian
portSaveBtn.MouseButton1Click:Connect(function()
    log("端口已保存为 " .. portInput.Text .. "，变更需要重启 Studio 后生效")
end)

-- ========================================
-- 轮询逻辑
-- ========================================
local HttpService = game:GetService("HttpService")

log("极导表已启动，正在监听本地工具...")
log(string.format("轮询地址：%s", "http://localhost:" .. (tonumber(portInput.Text) or 11451) .. "/poll"))

task.spawn(function()
    while true do
        task.wait(POLL_INTERVAL)

        -- 请求轮询接口 -- Ian
        local ok, response = pcall(function()
            return HttpService:RequestAsync({
                Url = "http://localhost:" .. (tonumber(portInput.Text) or 11451) .. "/poll",
                Method = "GET",
            })
        end)

        if not ok or not response.Success then
            -- 连接失败时静默跳过，不刷屏 -- Ian
            continue
        end

        -- 解析响应 -- Ian
        local decodeOk, data = pcall(function()
            return HttpService:JSONDecode(response.Body)
        end)

        if not decodeOk or not data.hasUpdate then
            continue
        end

        -- 有新数据，逐个写入 -- Ian
        log(string.format("收到 %d 个写入任务，开始写入...", #data.tasks))

        local successCount = 0
        local failCount = 0

        for _, task_ in ipairs(data.tasks) do
            local writeOk, writeErr = FileWriter:Write(task_.path, task_.fileName, task_.code)
            if writeOk then
                successCount = successCount + 1
                log(string.format("✓ 已写入 %s.%s", task_.path, task_.fileName))
            else
                failCount = failCount + 1
                log(string.format("✗ 写入失败 %s.%s : %s", task_.path, task_.fileName, tostring(writeErr)), true)
            end
        end

        log(string.format("完成：成功 %d，失败 %d", successCount, failCount))

        -- 通知本地工具已完成，携带写入结果 -- Ian
        pcall(function()
            HttpService:RequestAsync({
                Url = "http://localhost:" .. (tonumber(portInput.Text) or 11451) .. "/ack",
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = HttpService:JSONEncode({
                    success = successCount,
                    fail = failCount,
                    errors = {},
                }),
            })
        end)
    end
end)
]]></ProtectedString>			<int64 name="SourceAssetId">-1</int64>
