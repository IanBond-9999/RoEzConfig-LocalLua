		</Properties>

		<Item class="ModuleScript" referent="RBXA34E1A2998C9452D815F5A4E">
			<Properties>
				<BinaryString name="AttributesSerialize" />
				<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
				<bool name="DefinesCapabilities">false</bool>
				<bool name="Disabled">false</bool>
				<Content name="LinkedSource">
					<null />
				</Content>
				<string name="Name">FileWriter</string>
				<string name="ScriptGuid">{6E2ADA42-E1F8-4D1C-9F6B-0C379700800A}</string>
				<ProtectedString name="Source"><![CDATA[--[[
	FileWriter 模块 — ModuleScript 创建与更新
	负责将生成的 Lua 代码写入到 Studio 工程的指定路径
	作者：Ian
]]

local ScriptEditorService = game:GetService("ScriptEditorService")

local FileWriter = {}

--[[
	解析点分隔的路径字符串，返回对应的 Roblox 实例
	例如 "ReplicatedStorage.Data" → game.ReplicatedStorage.Data
	如果中间的文件夹不存在则自动创建
	@param pathStr - 点分隔的路径，如 "ReplicatedStorage.Data.Config"
	@return Instance? 目标文件夹实例
	@return string? 错误信息
	-- Ian
]]
local function resolvePath(pathStr)
	local parts = string.split(pathStr, ".")
	if #parts == 0 then
		return nil, "路径不能为空"
	end

	-- 第一个部分必须是 Service 名称 -- Ian
	local ok, service = pcall(function()
		return game:GetService(parts[1])
	end)
	if not ok or not service then
		return nil, string.format("无法找到服务: %s", parts[1])
	end

	-- 逐级查找或创建文件夹 -- Ian
	local current = service
	for i = 2, #parts do
		local child = current:FindFirstChild(parts[i])
		if not child then
			child = Instance.new("Folder")
			child.Name = parts[i]
			child.Parent = current
		end
		current = child
	end

	return current
end

--[[
	将 Lua 源码写入到指定路径的 ModuleScript
	如果 ModuleScript 不存在则创建，存在则更新内容
	@param pathStr - 目标路径（点分隔），如 "ReplicatedStorage.Data"
	@param fileName - ModuleScript 名称
	@param content - Lua 源码内容
	@return boolean 是否成功
	@return string? 错误信息
	-- Ian
]]
function FileWriter:Write(pathStr, fileName, content)
	-- 解析路径 -- Ian
	local folder, pathErr = resolvePath(pathStr)
	if not folder then
		return false, pathErr
	end

	-- 查找或创建 ModuleScript -- Ian
	local file = folder:FindFirstChild(fileName)
	if not file then
		file = Instance.new("ModuleScript")
		file.Name = fileName
		file.Parent = folder
	end

	-- 使用 ScriptEditorService 更新源码 -- Ian
	local ok, err = pcall(function()
		ScriptEditorService:UpdateSourceAsync(file, function()
			return content
		end)
	end)

	if not ok then
		return false, "写入脚本失败: " .. tostring(err)
	end

	return true
end

return FileWriter
]]></ProtectedString>
				<int64 name="SourceAssetId">-1</int64>
				<BinaryString name="Tags" />
